{
  "name": "@lobster/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./const": {
      "import": "./dist/const.js",
      "types": "./dist/const.d.ts"
    },
