# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ─── Ollama (local AI) ──────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Optional: custom system prompt for the assistant
# SYSTEM_PROMPT=You are Lobster, a helpful AI assistant.

# ─── Rate limiting ──────────────────────────────────────────
INTERNAL_API_KEY=change-me-to-something-secret

# ─── OAuth (optional) ─────────────────────────────────────────
# Leave blank to use anonymous sessions
OAUTH_PORTAL_URL=
APP_ID=
APP_SECRET=

# ─── Bots ──────────────────────────────────────────────────────
DISCORD_TOKEN=
TELEGRAM_TOKEN=
WHATSAPP_ENABLED=false

# ─── Client (Vite) ─────────────────────────────────────────────
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
