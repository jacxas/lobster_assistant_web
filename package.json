{
  "name": "@lobster/root",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@lobster/web",
    "dev:server": "turbo run dev --filter=@lobster/server",
    "dev:bot": "turbo run dev --filter=@lobster/bot",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check": "turbo run check",
    "db:migrate": "turbo run db:migrate --filter=@lobster/server",
    "setup": "node apps/bot/setup.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.6.0",
    "typescript": "^5.6.0"
  }
}
